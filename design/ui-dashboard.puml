@startuml
title Inspector Dashboard UI

rectangle "App Shell" {
	rectangle "Top Bar\nSearch | Date Range | Region" as TopBar
	rectangle "Scenario Switcher\nToday | Selected Day | 7-Day View" as ScenarioSwitcher
	rectangle "Filter Panel\nCrop | Risk | Alert State" as Filters
	rectangle "Map View\nRisk layers and farm boundaries" as MapView
	rectangle "Ranked Fields\nHigh risk to low risk" as Ranking
	rectangle "Field Detail Drawer\nScores, evidence, meter proof" as Details
	rectangle "Prediction Timeline\nDaily forecast vs actual use" as Timeline
	rectangle "Alerts Panel\nNew alerts and acknowledgement" as AlertsPanel
}

TopBar -down- ScenarioSwitcher
ScenarioSwitcher -down- Filters
Filters -down- MapView
MapView -right- Ranking
MapView -down- Details
Details -down- Timeline
Ranking -down- AlertsPanel

@enduml