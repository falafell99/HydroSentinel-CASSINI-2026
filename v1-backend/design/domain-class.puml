@startuml
title Domain Class Diagram

class Farm {
	+id: UUID
	+name: string
	+boundary: Polygon
	+ownerId: UUID
}

class Parcel {
	+id: UUID
	+geometry: Polygon
	+registryRef: string
}

class Observation {
	+id: UUID
	+capturedAt: DateTime
	+source: string
	+type: string
}

class SatelliteObservation {
	+bandSet: string
	+ndvi: float
	+soilWetness: float
	+selectedDay: Date
}

class ForecastScenario {
	+id: UUID
	+day: Date
	+rainfallForecast: float
	+irrigationNeedEstimate: float
	+stressBand: string
}

class MeterReading {
	+id: UUID
	+volumeLiters: float
	+gpsLat: float
	+gpsLng: float
	+osnmaValid: boolean
	+capturedAt: DateTime
}

class WasteScore {
	+id: UUID
	+value: float
	+riskBand: string
	+explanation: string
}

class Alert {
	+id: UUID
	+severity: string
	+status: string
	+createdAt: DateTime
}

class Inspector {
	+id: UUID
	+name: string
	+region: string
}

Farm "1" o-- "many" Parcel
Farm "1" o-- "many" Observation
Observation <|-- SatelliteObservation
Observation <|-- MeterReading
Farm "1" o-- "many" ForecastScenario
Farm "1" o-- "many" WasteScore
Farm "1" o-- "many" Alert
Inspector "1" --> "many" Alert : receives
ForecastScenario --> Farm
WasteScore --> Farm
MeterReading --> Farm : matched to boundary

@enduml